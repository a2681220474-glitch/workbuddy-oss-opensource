{
  "name": "workagent-cn",
  "private": true,
  "version": "1.1.16",
  "description": "WorkBuddy OSS monorepo",
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "services:start": ".venv/bin/python scripts/manage_local_services.py start",
    "services:stop": ".venv/bin/python scripts/manage_local_services.py stop",
    "services:restart": ".venv/bin/python scripts/manage_local_services.py restart",
    "services:status": ".venv/bin/python scripts/manage_local_services.py status",
    "services:logs": ".venv/bin/python scripts/manage_local_services.py logs",
    "db:migrate": ".venv/bin/python scripts/run_migrations.py",
    "backup:create": ".venv/bin/python scripts/manage_backups.py create",
    "backup:verify": ".venv/bin/python scripts/manage_backups.py verify",
    "backup:restore-plan": ".venv/bin/python scripts/manage_backups.py restore-plan",
    "backup:restore:sqlite": ".venv/bin/python scripts/manage_backups.py restore-sqlite",
    "check:postgres-restore-drill": ".venv/bin/python scripts/check_postgres_restore_drill.py",
    "check:backup": ".venv/bin/python scripts/manage_backups.py create",
    "logs:tail": ".venv/bin/python scripts/check_logs.py tail",
    "check:logs": ".venv/bin/python scripts/check_logs.py status",
    "dev:feishu-stream": "ENABLE_REAL_IM_ADAPTERS=true .venv/bin/python -m apps.api.workers.feishu_stream",
    "dev:runtime-jobs": "ENABLE_BACKGROUND_JOBS=true .venv/bin/python -m apps.api.workers.runtime_jobs",
    "check:background-jobs": "ENABLE_BACKGROUND_JOBS=true .venv/bin/python -m apps.api.workers.runtime_jobs --check",
    "check:deployment": ".venv/bin/python scripts/check_deployment.py",
    "check:feishu-stream": "ENABLE_REAL_IM_ADAPTERS=true .venv/bin/python -m apps.api.workers.feishu_stream --check",
    "check:feishu-acceptance": ".venv/bin/python scripts/run_feishu_acceptance.py",
    "check:runtime-stack": ".venv/bin/python scripts/check_runtime_stack.py",
    "check:wecom-runtime": ".venv/bin/python scripts/check_wecom_runtime.py",
    "check:wecom-acceptance": ".venv/bin/python scripts/run_wecom_acceptance.py",
    "check:local-acceptance": ".venv/bin/python scripts/check_local_acceptance.py",
    "check:product-workflow": ".venv/bin/python scripts/check_product_workflow.py",
    "check:rag-workflow": ".venv/bin/python scripts/check_rag_workflow.py",
    "check:connector-acceptance": ".venv/bin/python scripts/check_connector_acceptance.py",
    "check:release-gap-audit": ".venv/bin/python scripts/check_release_gap_audit.py",
    "check:frontend-maintenance": ".venv/bin/python scripts/check_frontend_maintenance.py",
    "check:ui-smoke": ".venv/bin/python scripts/check_ui_smoke.py",
    "check:formal-closure": ".venv/bin/python scripts/check_formal_closure.py",
    "check:formal-release": "npm run check:release-gap-audit && npm run check:formal-closure && npm run check:postgres-restore-drill && npm run check:frontend-maintenance && npm run check:ui-smoke && npm run check:product-workflow && npm run check:rag-workflow && npm run check:connector-acceptance && npm run check:rc && npm run check:local-acceptance && npm run build:web && npm run check:web-bundle",
    "check:local-services": ".venv/bin/python scripts/check_local_service_manager.py",
    "check:web-bundle": "node scripts/check_web_bundle.mjs",
    "check:secret-storage": ".venv/bin/python scripts/check_secret_storage.py",
    "check:release": ".venv/bin/python scripts/check_release_readiness.py",
    "check:rc": ".venv/bin/python scripts/check_release_candidate.py",
    "check:private-deploy": ".venv/bin/python scripts/check_private_deployment.py"
  }
}
