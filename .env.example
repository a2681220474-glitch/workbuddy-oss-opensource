# WorkBuddy OSS local runtime settings

APP_ENV=development
APP_NAME=WorkBuddy OSS

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Public HTTPS base URL used by Feishu interactive card callbacks.
# Example: WORKBUDDY_PUBLIC_BASE_URL=https://workbuddy.example.com
WORKBUDDY_PUBLIC_BASE_URL=

# Web
WEB_HOST=0.0.0.0
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite:///./apps/api/data/workbuddy.db
REDIS_URL=

# LLM
# Default is mock/demo mode. To use DeepSeek/OpenAI/Qwen/Moonshot, set:
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=...
LLM_PROVIDER=mock
LLM_MODEL=workbuddy-demo
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=30

# Agent runtime
AGENT_ROUTER_MODE=rules_first
REQUIRE_APPROVAL_FOR_EXTERNAL_REPLIES=true
ENABLE_REAL_IM_ADAPTERS=false
ENABLE_EXTERNAL_SEND=false
ENABLE_BACKGROUND_JOBS=false
BACKGROUND_QUEUE_DRIVER=database_polling
BACKGROUND_JOBS_STATUS_PATH=apps/api/data/runtime_jobs_status.json
BACKGROUND_JOBS_INTERVAL_SECONDS=30

# Demo
DEMO_SEED_ON_START=false
DEMO_DATA_DIR=../../examples

# Channel adapters.
# For HTTP webhook mode, expose /api/channels/feishu/webhook through a public tunnel.
# Feishu approval card buttons also require that same public HTTPS webhook.
# For local stream mode, set ENABLE_REAL_IM_ADAPTERS=true and run:
# python -m apps.api.workers.feishu_stream
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_STREAM_STATUS_PATH=apps/api/data/feishu_stream_status.json

# WeCom can be configured here first, then tested through:
# POST /api/channels/wecom/webhook
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# DingTalk can be configured here first, then tested through:
# POST /api/channels/dingtalk/webhook
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_WEBHOOK_SECRET=
